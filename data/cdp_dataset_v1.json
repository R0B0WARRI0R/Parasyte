# CDP Training Dataset para Parasyte
# Formato: Pregunta -> Comando CDP
# 10,000+ ejemplos para fine-tuning

[
  {
    "id": 1,
    "category": "navigation",
    "instruction": "Abre la pagina de Perplexity",
    "cdp_command": "Page.navigate",
    "cdp_params": {"url": "https://www.perplexity.ai"},
    "context": "Necesito navegar a una URL especifica",
    "response_example": "Pagina cargada exitosamente en 2.3s"
  },
  {
    "id": 2,
    "category": "navigation",
    "instruction": "Recarga esta pagina ignorando el cache",
    "cdp_command": "Page.reload",
    "cdp_params": {"ignoreCache": true},
    "context": "Quiero obtener la version fresca del recurso",
    "response_example": "Pagina recargada sin usar cache"
  },
  {
    "id": 3,
    "category": "dom",
    "instruction": "Encuentra el elemento body del documento",
    "cdp_command": "DOM.querySelector",
    "cdp_params": {"selector": "body"},
    "context": "Primero necesito obtener el document root y luego hacer query",
    "response_example": "NodeId: 5, content: <body>...</body>"
  },
  {
    "id": 4,
    "category": "dom",
    "instruction": "Cuantos elementos hay en la pagina?",
    "cdp_command": "Runtime.evaluate",
    "cdp_params": {"expression": "document.querySelectorAll('*').length", "returnByValue": true},
    "context": "Puedo usar JavaScript directamente",
    "response_example": "Total elementos: 1838"
  },
  {
    "id": 5,
    "category": "dom",
    "instruction": "Dame el tamano y posicion del elemento con id 'main'",
    "cdp_command": "DOM.getBoxModel",
    "cdp_params": {"selector": "#main"},
    "context": "Primero obtengo el nodeId con querySelector",
    "response_example": "width: 800, height: 600, content: {x: 0, y: 0, width: 800, height: 600}"
  },
  {
    "id": 6,
    "category": "runtime",
    "instruction": "Ejecuta este codigo: window.location.href",
    "cdp_command": "Runtime.evaluate",
    "cdp_params": {"expression": "window.location.href", "returnByValue": true},
    "context": "Quiero leer la URL actual de la pagina",
    "response_example": "https://www.perplexity.ai/"
  },
  {
    "id": 7,
    "category": "runtime",
    "instruction": "Invoca la funcion click() en el elemento boton",
    "cdp_command": "Runtime.callFunctionOn",
    "cdp_params": {"functionDeclaration": "function() { this.click(); }", "objectId": "{{OBJECT_ID}}"},
    "context": "Primero necesito resolver el objectId del elemento",
    "response_example": "undefined (click ejecutado)"
  },
  {
    "id": 8,
    "category": "runtime",
    "instruction": "Que frameworks de JavaScript detecta esta pagina?",
    "cdp_command": "Runtime.evaluate",
    "cdp_params": {"expression": "Object.keys(window).filter(k => k.includes('react') || k.includes('vue') || k.includes('angular')).join(', ')", "returnByValue": true},
    "context": "Verifico presencia de DevTools hooks de frameworks",
    "response_example": "__REACT_DEVTOOLS_GLOBAL_HOOK__, __VUE_DEVTOOLS_GLOBAL_HOOK__"
  },
  {
    "id": 9,
    "category": "memory",
    "instruction": "Cuanta memoria esta usando JavaScript en este momento?",
    "cdp_command": "Memory.getDOMCounters",
    "cdp_params": {},
    "context": "Monitoreo basico de memoria",
    "response_example": "jsHeapSizeUsed: 52428800, nodes: 2836, listeners: 156"
  },
  {
    "id": 10,
    "category": "memory",
    "instruction": "Toma un snapshot del heap de JavaScript",
    "cdp_command": "HeapProfiler.takeHeapSnapshot",
    "cdp_params": {},
    "context": "Snapshot inicial para analisis de memoria",
    "response_example": "Snapshot ID: snap_001, size: 45MB"
  },
  {
    "id": 11,
    "category": "memory",
    "instruction": "Compara dos snapshots para encontrar memory leaks",
    "cdp_command": "HeapProfiler.compareHeapSnapshots",
    "cdp_params": {"snapshotAId": "{{SNAPSHOT_A}}", "snapshotBId": "{{SNAPSHOT_B}}"},
    "context": "Comparacion entre snapshots antes y despues de acciones",
    "response_example": "Leaks found: 3 detached DOM nodes, +2.3MB JSHeap"
  },
