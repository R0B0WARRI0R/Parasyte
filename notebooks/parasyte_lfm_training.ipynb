  "cells": [
    {
      "cell_type": "markdown",
      "source": [
        "# PARASYTE - Entrenamiento de LFM para CDP\n",
        "\n",
        "## Fine-tuning de LFM 2.5-1.2B para dominar Chrome DevTools Protocol\n",
        "\n",
        "Este notebook entrena un modelo para convertirse en experto en comandos CDP."
      ],
      "metadata": {"id": "header"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 1. Instalar dependencias\n",
        "!pip install -q transformers peft datasets accelerate bitsandbytes\n",
        "!pip install -q unsloth\n",
        "!pip install -q httpx 2>/dev/null || true"
      ],
      "metadata": {"id": "install"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 2. Verificar GPU\n",
        "import torch\n",
        "print(f\"GPU disponible: {torch.cuda.is_available()}\")\n",
        "if torch.cuda.is_available():\n",
        "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
        "    print(f\"VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB\")"
      ],
      "metadata": {"id": "gpu_check"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 3. Clonar repositorio y cargar dataset\n",
        "!git clone https://github.com/R0B0WARRI0R/Parasyte.git 2>/dev/null || echo \"Repo ya clonado\"\n",
        "import json\n",
        "import os\n",
        "\n",
        "# Cargar el dataset v2 (mapeo semantico correcto)\n",
        "dataset_path = \"Parasyte/data/cdp_training_v2.json\"\n",
        "if os.path.exists(dataset_path):\n",
        "    with open(dataset_path, \"r\", encoding=\"utf-8\") as f:\n",
        "        raw_data = json.load(f)\n",
        "    print(f\"Dataset cargado: {len(raw_data)} ejemplos\")\n",
        "    print(f\"Categorias: {set(d['category'] for d in raw_data)}\")\n",
        "    print(f\"Comandos unicos: {set(d['cdp_command'] for d in raw_data)}\")\n",
        "else:\n",
        "    print(\"ERROR: Dataset no encontrado\")\n",
        "    print(\"Generando dataset...\")\n",
        "    # Generar inline si no existe\n",
        "    raw_data = []"
      ],
      "metadata": {"id": "dataset"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 4. Formatear dataset para entrenamiento\n",
        "from datasets import Dataset\n",
        "\n",
        "def format_example(example):\n",
        "    \"\"\"Formatea ejemplo para training con pares instruction->CDP\"\"\"\n",
        "    instruction = example[\"instruction\"]\n",
        "    command = example[\"cdp_command\"]\n",
        "    params = example[\"cdp_params\"]\n",
        "    context = example.get(\"context\", \"\")\n",
        "    \n",
        "    # Formato instructivo en espanol\n",
        "    text = f\"\"\"Eres un experto en Chrome DevTools Protocol.\n",
        "Instruction: {instruction}\n",
        "Contexto: {context}\n",
        "CDP Command: {command}\n",
        "Params: {json.dumps(params, ensure_ascii=False)}\"\"\"\n",
        "    \n",
        "    return {\"text\": text}\n",
        "\n",
        "# Formatear\n",
        "formatted_data = [format_example(ex) for ex in raw_data]\n",
        "dataset = Dataset.from_list(formatted_data)\n",
        "\n",
        "print(f\"Dataset formateado: {len(dataset)} ejemplos\")\n",
        "print(f\"\\nEjemplo 1:\\n{dataset[0]['text']}\")"
      ],
      "metadata": {"id": "format_data"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 5. Cargar modelo base\n",
        "from unsloth import FastLanguageModel\n",
        "\n",
        "# Configuracion\n",
        "model_name = \"liquid/lfm-2.5-1.2b-instruct\"  # o liquid/lfm-1.2b-instruct\n",
        "max_seq_length = 1024  # Mas pequeno para dataset especifico\n",
        "dtype = None\n",
        "load_in_4bit = True\n",
        "\n",
        "print(\"Cargando modelo base...\")\n",
        "model, tokenizer = FastLanguageModel.from_pretrained(\n",
        "    model_name = model_name,\n",
        "    max_seq_length = max_seq_length,\n",
        "    dtype = dtype,\n",
        "    load_in_4bit = load_in_4bit,\n",
        ")\n",
        "print(f\"Modelo: {model.num_parameters():,} parametros\")"
      ],
      "metadata": {"id": "load_model"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 6. Configurar LoRA\n",
        "model = FastLanguageModel.get_peft_model(\n",
        "    model,\n",
        "    r = 16,\n",
        "    target_modules = [\n",
        "        \"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\",\n",
        "        \"gate_proj\", \"up_proj\", \"down_proj\",\n",
        "    ],\n",
        "    lora_alpha = 16,\n",
        "    lora_dropout = 0,\n",
        "    bias = \"none\",\n",
        "    use_gradient_checkpointing = \"unsloth\",\n",
        "    random_state = 42,\n",
        ")\n",
        "\n",
        "trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
        "print(f\"LoRA aplicado. Parametros entrenables: {trainable:,} ({trainable/model.num_parameters()*100:.1f}%)\")"
      ],
      "metadata": {"id": "lora_config"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 7. Tokenizar dataset\n",
        "def tokenize_function(examples):\n",
        "    result = tokenizer(\n",
        "        examples[\"text\"],\n",
        "        truncation = True,\n",
        "        max_length = max_seq_length,\n",
        "        padding = \"max_length\",\n",
        "    )\n",
        "    result[\"labels\"] = result[\"input_ids\"].copy()\n",
        "    return result\n",
        "\n",
        "tokenized_dataset = dataset.map(\n",
        "    tokenize_function,\n",
        "    batched = True,\n",
        "    remove_columns = [\"text\"]\n",
        ")\n",
        "\n",
        "avg_tokens = sum(len(x[\"input_ids\"]) for x in tokenized_dataset) / len(tokenized_dataset)\n",
        "print(f\"Dataset tokenizado: {len(tokenized_dataset)} ejemplos\")\n",
        f\"print(f\\\"Longitud media: {avg_tokens:.0f} tokens\\\")\""
      ],
      "metadata": {"id": "tokenize"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 8. Configurar entrenamiento\n",
        "from transformers import TrainingArguments\n",
        "from unsloth import is_bfloat16_supported\n",
        "\n",
        "training_args = TrainingArguments(\n",
        "    per_device_train_batch_size = 4,\n",
        "    gradient_accumulation_steps = 4,\n",
        "    warmup_steps = 10,\n",
        "    num_train_epochs = 3,\n",
        "    learning_rate = 2e-4,\n",
        "    fp16 = not is_bfloat16_supported(),\n",
        "    bf16 = is_bfloat16_supported(),\n",
        "    logging_steps = 1,\n",
        "    optim = \"adamw_8bit\",\n",
        "    weight_decay = 0.01,\n",
        "    lr_scheduler_type = \"linear\",\n",
        "    seed = 42,\n",
        "    output_dir = \"outputs\",\n",
        "    report_to = \"none\",\n",
        ")\n",
        "\n",
        "print(\"Configuracion lista\")"
      ],
      "metadata": {"id": "train_config"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 9. Entrenar\n",
        "from trl import SFTTrainer\n",
        "\n",
        "trainer = SFTTrainer(\n",
        "    model = model,\n",
        "    tokenizer = tokenizer,\n",
        "    train_dataset = tokenized_dataset,\n",
        "    dataset_text_field = \"text\",\n",
        "    max_seq_length = max_seq_length,\n",
        "    dataset_num_proc = 2,\n",
        "    packing = False,\n",
        "    args = training_args,\n",
        ")\n",
        "\n",
        "print(\"Iniciando entrenamiento...\")\n",
        "print(f\"Pasos totales: {len(tokenized_dataset) // (4 * 4) * 3}\")\n",
        "trainer.train()"
      ],
      "metadata": {"id": "train"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 10. Guardar modelo\n",
        "model.save_pretrained(\"parasyte_cdp_expert\")\n",
        "tokenizer.save_pretrained(\"parasyte_cdp_expert\")\n",
        "\n",
        "# Opcional: guardar en Google Drive\n",
        "# from google.colab import drive\n",
        "# drive.mount('/content/drive')\n",
        "# !cp -r parasyte_cdp_expert /content/drive/MyDrive/\n",
        "\n",
        "print(\"Modelo guardado: parasyte_cdp_expert/\")"
      ],
      "metadata": {"id": "save"}
    },
    {
      "cell_type": "code",
      "executionInfo": {"status": "ok", "timinging": []},
      "source": [
        "# @title 11. Probar modelo\n",
        "FastLanguageModel.for_inference(model)\n",
        "\n",
        "test_instrucciones = [\n",
        "    \"Cuanta memoria usa JavaScript?\",\n",
        "    \"Pon un breakpoint en la linea 42\",\n",
        "    \"Activa el debugger\",\n",
        "    \"Hay errores en consola?\",\n",
        "    \"Navega a google.com\",\n",
        "]\n",
        "\n",
        "for instr in test_instrucciones:\n",
        "    prompt = f\"\"\"Eres un experto en Chrome DevTools Protocol.\n",
        "Instruction: {instr}\n",
        "Contexto: Analisis automatizado\n",
        \"CDP Command:\"\"\"\n",
        "    \n",
        "    inputs = tokenizer(prompt, return_tensors = \"pt\").to(\"cuda\")\n",
        "    \n",
        "    outputs = model.generate(\n",
        "        **inputs,\n",
        "        max_new_tokens = 64,\n",
        "        use_cache = True,\n",
        "    )\n",
        "    respuesta = tokenizer.batch_decode(outputs, skip_special_tokens = True)[0]\n",
        "    \n",
        "    print(f\"\\nPregunta: {instr}\")\n",
        "    print(f\"Respuesta: {respuesta}\")"
      ],
      "metadata": {"id": "test"}
    },
    {
      "cell_type": "markdown",
      "source": [
        "---\n",
        "## Siguientes pasos\n",
        "\n",
