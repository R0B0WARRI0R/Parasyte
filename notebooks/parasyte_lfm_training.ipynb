  "cells": [
    {
      "cell_type": "markdown",
      "source": [
        "# PARASYTE LFM Training\n",
        "## Fine-tuning LFM 2.5-1.2B para ser experto en CDP (Chrome DevTools Protocol)\n",
        "\n",
        "Este notebook entrena un LLM para dominar los comandos de DevTools."
      ],
      "metadata": {"id": "header"}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 1. Instalar dependencias\n",
        "!pip install -q transformers peft datasets accelerate bitsandbytes\n",
        "!pip install -q unsloth  # Optimizacion para fine-tuning eficiente\n",
        "!pip install -q httpx  # Para descargar el dataset"
      ],
      "metadata": {"id": "install"},
      "execution": {"start_time_bar": 0}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 2. Configurar GPU\n",
        "import torch\n",
        "print(f\"GPU disponible: {torch.cuda.is_available()}\")\n",
        "if torch.cuda.is_available():\n",
        "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
        "    print(f\"VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB\")"
      ],
      "metadata": {"id": "gpu_check"},
      "execution": {"start_time_bar": 1}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 3. Clonar repositorio y cargar dataset\n",
        "!git clone https://github.com/R0B0WARRI0R/Parasyte.git\n",
        "import json\n",
        "import os\n",
        "\n",
        "with open('Parasyte/data/cdp_dataset_v1.json', 'r') as f:\n",
        "    raw_data = json.load(f)\n",
        "\n",
        "print(f\"Dataset cargado: {len(raw_data)} ejemplos\")\n",
        "print(f\"Categorias: {set(d['category'] for d in raw_data)}\")"
      ],
      "metadata": {"id": "dataset"},
      "execution": {"start_time_bar": 2}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 4. Crear dataset de entrenamiento\n",
        "from datasets import Dataset\n",
        "\n",
        "def format_example(example):\n",
        "    \"\"\"Formatea un ejemplo para training\"\"\"\n",
        "    instruction = example['instruction']\n",
        "    command = example['cdp_command']\n",
        "    params = example['cdp_params']\n",
        "    context = example.get('context', '')\n",
        "    \n",
        "    # Prompt en formato instructivo\n",
        "    text = f\"\"\"你是 DevTools 专家。\n",
        f\"指令: {instruction}\n",
        f\"上下文: {context}\n",
        f\"命令: {command}\n",
        f\"参数: {json.dumps(params, ensure_ascii=False)}\n",
        f\"结果示例: {example.get('response_example', '')}\"\"\"\n",
        "    \n",
        "    return {'text': text}\n",
        "\n",
        "# Formatear todos los ejemplos\n",
        "formatted_data = [format_example(ex) for ex in raw_data]\n",
        "\n",
        "# Crear dataset HuggingFace\n",
        "dataset = Dataset.from_list(formatted_data)\n",
        "print(f\"Dataset listo: {len(dataset)} ejemplos\")\n",
        "print(f\"Ejemplo: {dataset[0]['text'][:200]}...\")"
      ],
      "metadata": {"id": "format_data"},
      "execution": {"start_time_bar": 3}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 5. Cargar modelo base\n",
        "from unsloth import FastLanguageModel\n",
        "\n",
        "# Configuracion\n",
        "model_name = \"liquid/lfm-2.5-1.2b-instruct\"  # O lfm-2.5-1.2b-instruct\n",
        "max_seq_length = 2048\n",
        "dtype = None  # Auto-detecta\n",
        "load_in_4bit = True  # Cuantizacion 4-bit para ahorrar VRAM\n",
        "\n",
        "print(\"Cargando modelo...\")\n",
        "model, tokenizer = FastLanguageModel.from_pretrained(\n",
        "    model_name = model_name,\n",
        "    max_seq_length = max_seq_length,\n",
        "    dtype = dtype,\n",
        "    load_in_4bit = load_in_4bit,\n",
        ")\n",
        "print(f\"Modelo cargado: {model.num_parameters():,} parametros\")"
      ],
      "metadata": {"id": "load_model"},
      "execution": {"start_time_bar": 4}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 6. Configurar LoRA para fine-tuning eficiente\n",
        "model = FastLanguageModel.get_peft_model(\n",
        "    model,\n",
        "    r = 16,  # Rank de LoRA (mas alto = mas capacidad, mas VRAM)\n",
        "    target_modules = [\n",
        "        \"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\",\n",
        "        \"gate_proj\", \"up_proj\", \"down_proj\",\n",
        "    ],\n",
        "    lora_alpha = 16,\n",
        "    lora_dropout = 0,\n",
        "    bias = \"none\",\n",
        "    use_gradient_checkpointing = \"unsloth\",  # Usa less memory\n",
        "    random_state = 42,\n",
        "    use_rslora = False,\n",
        "    loftq_config = None,\n",
        ")\n",
        "\n",
        "print(f\"LoRA aplicado. Parametros entrenables: {sum(p.numel() for p in model.parameters() if p.requires_grad):,}\")"
      ],
      "metadata": {"id": "lora_config"},
      "execution": {"start_time_bar": 5}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 7. Tokenizar dataset\n",
        "def tokenize_function(examples):\n",
        "    \"\"\"Tokeniza los textos del dataset\"\"\"\n",
        "    result = tokenizer(\n",
        "        examples['text'],\n",
        "        truncation = True,\n",
        "        max_length = max_seq_length,\n",
        "        padding = \"max_length\",\n",
        "    )\n",
        "    # Labels igual que input_ids para causallm\n",
        "    result['labels'] = result['input_ids'].copy()\n",
        "    return result\n",
        "\n",
        "tokenized_dataset = dataset.map(\n",
        "    tokenize_function,\n",
        "    batched = True,\n",
        "    remove_columns = ['text']\n",
        ")\n",
        "\n",
        "print(f\"Dataset tokenizado: {len(tokenized_dataset)} ejemplos\")\n",
        "print(f\"Longitud media de tokens: {sum(len(x['input_ids']) for x in tokenized_dataset) / len(tokenized_dataset):.0f}\")"
      ],
      "metadata": {"id": "tokenize"},
      "execution": {"start_time_bar": 6}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 8. Configurar entrenamiento\n",
        "from transformers import TrainingArguments\n",
        "from unsloth import is_bfloat16_supported\n",
        "\n",
        "training_args = TrainingArguments(\n",
        "    per_device_train_batch_size = 4,\n",
        "    gradient_accumulation_steps = 4,\n",
        "    warmup_steps = 10,\n",
        "    num_train_epochs = 3,  # 3 epochs es suficiente para dataset pequeno\n",
        "    learning_rate = 2e-4,\n",
        "    fp16 = not is_bfloat16_supported(),\n",
        "    bf16 = is_bfloat16_supported(),\n",
        "    logging_steps = 1,\n",
        "    optim = \"adamw_8bit\",\n",
        "    weight_decay = 0.01,\n",
        "    lr_scheduler_type = \"linear\",\n",
        "    seed = 42,\n",
        "    output_dir = \"outputs\",\n",
        "    report_to = \"none\",  # No reporta a wandb\n",
        ")\n",
        "\n",
        "print(\"Configuracion de entrenamiento lista\")"
      ],
      "metadata": {"id": "train_config"},
      "execution": {"start_time_bar": 7}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 9. Entrenar!\n",
        "from trl import SFTTrainer\n",
        "from transformers import Trainer\n",
        "\n",
        "trainer = SFTTrainer(\n",
        "    model = model,\n",
        "    tokenizer = tokenizer,\n",
        "    train_dataset = tokenized_dataset,\n",
        "    dataset_text_field = \"text\",\n",
        "    max_seq_length = max_seq_length,\n",
        "    dataset_num_proc = 2,\n",
        "    packing = False,  # No packing para este dataset\n",
        "    args = training_args,\n",
        ")\n",
        "\n",
        "print(\"Iniciando entrenamiento...\")\n",
        "print(f\"Pasos totales: {len(tokenized_dataset) // (training_args.per_device_train_batch_size * training_args.gradient_accumulation_steps) * training_args.num_train_epochs}\")\n",
        "\n",
        "trainer.train()"
      ],
      "metadata": {"id": "train"},
      "execution": {"start_time_bar": 8}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 10. Guardar modelo\n",
        "model.save_pretrained(\"parasyte_cdp_expert\")\n",
        "tokenizer.save_pretrained(\"parasyte_cdp_expert\")\n",
        "\n",
        "# Guardar en Google Drive (opcional)\n",
        "# from google.colab import drive\n",
        "# drive.mount('/content/drive')\n",
        "# !cp -r parasyte_cdp_expert /content/drive/MyDrive/\n",
        "\n",
        "print(\"Modelo guardado en: parasyte_cdp_expert/\")"
      ],
      "metadata": {"id": "save"},
      "execution": {"start_time_bar": 9}
    },
    {
      "cell_type": "code",
      "source": [
        "# @title 11. Probar el modelo\n",
        "FastLanguageModel.for_inference(model)\n",
        "\n",
        "test_instructions = [\n",
        "    \"Cuanta memoria esta usando JavaScript?\",\n",
        "    \"Pon un breakpoint en la linea 42\",\n",
        "    \"Activa el debugger\",\n",
        "    \"Que errores hay en consola?\",\n",
        "]\n",
        "\n",
        "for instr in test_instructions:\n",
        "    prompt = f\"\"\"你是 DevTools 专家。\n",
        f\"指令: {instr}\n",
        f\"上下文: Necesito analizar el navegador\n",
        f\"命令:\"\"\"\n",
        "    \n",
        "    inputs = tokenizer(prompt, return_tensors = \"pt\").to(\"cuda\")\n",
        "    \n",
        "    outputs = model.generate(\n",
        "        **inputs,\n",
        "        max_new_tokens = 128,\n",
        "        use_cache = True,\n",
        "    )\n",
        "    response = tokenizer.batch_decode(outputs, skip_special_tokens = True)[0]\n",
        "    \n",
        "    print(f\"\\nPregunta: {instr}\")\n",
        "    print(f\"Respuesta: {response}\")"
      ],
      "metadata": {"id": "test"},
      "execution": {"start_time_bar": 10}
    },
    {
      "cell_type": "markdown",
      "source": [
        "---\n",
        "## Siguientes pasos\n",
        "\n",
        "1. **Subir el modelo a HuggingFace**: `model.push_to_hub(\"tu-usuario/parasyte-cdp-expert\")`\n",
        "2. **Exportar a GGUF**: Para inference local con llama.cpp\n",
        "3. **Integrar con Parasyte**: Conectar el modelo fine-tunned al CDP bridge\n",
        "\n",
        "## Recursos\n",
        "\n",
        "- [Unsoth GitHub](https://github.com/unslothai/unsloth)\n",
        "- [PEFT Documentation](https://huggingface.co/docs/peft)\n",
        "- [Chrome DevTools Protocol](https://chromedevtools.github.io/devtools-protocol/)\n",
        "- [Liquid AI LFMs](https://liquid.ai/)"
      ]
    }
  ]
}